# ========================================
# Production Environment Configuration
# ========================================
# Copy this file to .env.production and fill in your values

# Domain Configuration
BASE_DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# GitHub Container Registry
GITHUB_ORG=your-github-org
GITHUB_REPO=lms
IMAGE_TAG=latest

# Database
POSTGRES_DB=lms_prod
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD_HERE

# JWT & Security Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=CHANGEME_GENERATE_RANDOM_SECRET
REFRESH_TOKEN_SECRET=CHANGEME_GENERATE_RANDOM_SECRET
CSRF_SECRET=CHANGEME_GENERATE_RANDOM_SECRET

# Mailgun Configuration
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# Traefik Dashboard Authentication (generate with: htpasswd -nb admin password)
# Example: admin:$apr1$xyz123...
TRAEFIK_AUTH=admin:$$apr1$$xyz123...
