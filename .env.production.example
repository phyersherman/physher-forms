# ========================================
# PhysherForms Production Environment
# ========================================
# Copy this file to .env.production and fill in your values

# Domain Configuration
BASE_DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# GitHub Container Registry
GITHUB_ORG=phyersherman
GITHUB_REPO=physher-forms
IMAGE_TAG=latest

# Database
POSTGRES_DB=physherforms_prod
POSTGRES_USER=physherforms
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD_HERE
# If POSTGRES_PASSWORD contains URL-reserved characters like @ : / ? #,
# set DATABASE_URL explicitly with a URL-encoded password.
# Example:
# DATABASE_URL=postgresql://physherforms:your%40encoded%3Apassword@postgres:5432/physherforms_prod?schema=public

# JWT & Security Secrets (generate each with: openssl rand -base64 32)
JWT_SECRET=CHANGEME_GENERATE_RANDOM_SECRET
ENCRYPTION_SECRET=CHANGEME_GENERATE_RANDOM_SECRET

# Mailgun Configuration
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# Traefik Dashboard Authentication (generate with: htpasswd -nb admin password)
# Example: admin:$apr1$xyz123...
TRAEFIK_AUTH=admin:$$apr1$$xyz123...
