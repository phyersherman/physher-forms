    "db:reset:dev": "prisma migrate reset --force",
    "db:push:dev": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^2.4.3",
