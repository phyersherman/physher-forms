generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String              @id @default(cuid())
  name                 String
  defaultLocale        String
  primaryColor         String?
  secondaryColor       String?
  logoUrl              String?
  allowedDomains       String[]            @default([]) // email domains allowed for respondent login
  is_template          Boolean             @default(false)
  createdAt            DateTime            @default(now())
  domains              Domain[]
  users                User[]
  emailConfigs         EmailConfig[]
  forms                Form[]
  verificationCodes    VerificationCode[]
}

model Domain {
  id        String  @id @default(cuid())
  host      String  @unique
  isPrimary Boolean @default(false)
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                       String                    @id @default(cuid())
  email                    String
  password                 String?
  fullName                 String?
  role                     String                    @default("learner")
  tenantId                 String?
  status                   String                    @default("active") // "active" | "invited" | "disabled"
  authMethod               String                    @default("password") // "password" | "passwordless"
  organization             String?
  inviteToken              String?                   @unique
  inviteExpires            DateTime?
  resetToken               String?                   @unique
  resetExpires             DateTime?
  lastLoginAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  tenant                   Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens            RefreshToken[]
  magicCodes               MagicCode[]
  bulkImports              BulkImportJob[]

  @@unique([email, tenantId])
}

// Bulk User Management
model BulkImportJob {
  id           String    @id @default(cuid())
  tenantId     String
  importedBy   String
  fileName     String?
  totalRows    Int
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  status       String    @default("processing") // "processing" | "completed" | "failed"
  sendInvites  Boolean   @default(false)
  errors       String? // JSON array of error messages
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  importer     User      @relation(fields: [importedBy], references: [id])

  @@index([tenantId])
  @@index([importedBy])
}

model MagicCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailConfig {
  id           String   @id @default(cuid())
  tenantId     String?  @unique // null = global config
  provider     String   @default("mailgun") // future: sendgrid, ses
  apiKey       String // encrypted at rest
  domain       String // mailgun sending domain
  fromEmail    String // noreply@example.com
  fromName     String // "PhysherForms"
  replyToEmail String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id             String   @id @default(cuid())
  tenantId       String?
  recipientEmail String
  subject        String
  templateName   String
  status         String   @default("sent") // "sent" | "failed" | "bounced"
  providerMsgId  String? // mailgun message ID
  errorMessage   String?
  sentAt         DateTime @default(now())
}

// PhysherForms: Form management
model Form {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  jotformEmbedUrl String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  completions     FormCompletion[]

  @@index([tenantId])
}

// PhysherForms: Tracks which respondents completed which forms
// emailHash = SHA-256 of respondent email (never store plaintext email here)
// displayHint = masked email computed at write time, e.g. "t***@example.com"
model FormCompletion {
  id          String   @id @default(cuid())
  emailHash   String   // SHA-256 hash of respondent email
  displayHint String   // masked email for admin display, e.g. "t***@example.com"
  formId      String
  completedAt DateTime @default(now())
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([emailHash, formId])
  @@index([formId])
  @@index([emailHash])
}

// PhysherForms: Temporary 6-digit OTP codes for respondent email verification
// Stored only for the 10-minute TTL; cleaned up by cron job
model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  tenantId  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email, tenantId])
  @@index([expiresAt])
}

